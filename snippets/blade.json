{
  "@if": {
    "prefix": "@if",
    "body": ["@if(${1:condition})", "\t$0", "@endif"],
    "description": "Blade if statement"
  },
  "@else": {
    "prefix": "@else",
    "body": ["@else"],
    "description": "Blade else"
  },
  "@elseif": {
    "prefix": "@elseif",
    "body": ["@elseif(${1:condition})"],
    "description": "Blade elseif"
  },
  "@foreach": {
    "prefix": "@foreach",
    "body": ["@foreach(${1:\\$items} as ${2:\\$item})", "\t$0", "@endforeach"],
    "description": "Blade foreach loop"
  },
  "@for": {
    "prefix": "@for",
    "body": ["@for(${1:\\$i = 0; \\$i < count; \\$i++})", "\t$0", "@endfor"],
    "description": "Blade for loop"
  },
  "@while": {
    "prefix": "@while",
    "body": ["@while(${1:condition})", "\t$0", "@endwhile"],
    "description": "Blade while loop"
  },
  "@forelse": {
    "prefix": "@forelse",
    "body": [
      "@forelse(${1:\\$items} as ${2:\\$item})",
      "\t$0",
      "@empty",
      "\t",
      "@endforelse"
    ],
    "description": "Blade forelse loop"
  },
  "@auth": {
    "prefix": "@auth",
    "body": ["@auth", "\t$0", "@endauth"],
    "description": "Blade auth block"
  },
  "@guest": {
    "prefix": "@guest",
    "body": ["@guest", "\t$0", "@endguest"],
    "description": "Blade guest block"
  },
  "@can": {
    "prefix": "@can",
    "body": ["@can(${1:'ability'})", "\t$0", "@endcan"],
    "description": "Blade can block"
  },
  "@cannot": {
    "prefix": "@cannot",
    "body": ["@cannot(${1:'ability'})", "\t$0", "@endcannot"],
    "description": "Blade cannot block"
  },
  "@canany": {
    "prefix": "@canany",
    "body": ["@canany([${1:'ability1', 'ability2'}])", "\t$0", "@endcanany"],
    "description": "Blade canany block"
  },
  "@switch": {
    "prefix": "@switch",
    "body": [
      "@switch(${1:\\$value})",
      "\t@case(${2:value})",
      "\t\t$0",
      "\t\t@break",
      "\t@default",
      "\t\t",
      "@endswitch"
    ],
    "description": "Blade switch statement"
  },
  "@section": {
    "prefix": "@section",
    "body": ["@section('${1:name}')", "\t$0", "@endsection"],
    "description": "Blade section block"
  },
  "@yield": {
    "prefix": "@yield",
    "body": ["@yield('${1:name}')"],
    "description": "Blade yield"
  },
  "@extends": {
    "prefix": "@extends",
    "body": ["@extends('${1:layout}')"],
    "description": "Blade extends"
  },
  "@include": {
    "prefix": "@include",
    "body": ["@include('${1:view}')"],
    "description": "Blade include"
  },
  "@includeIf": {
    "prefix": "@includeIf",
    "body": ["@includeIf('${1:view}')"],
    "description": "Blade includeIf"
  },
  "@includeWhen": {
    "prefix": "@includeWhen",
    "body": ["@includeWhen(${1:condition}, '${2:view}')"],
    "description": "Blade includeWhen"
  },
  "@includeUnless": {
    "prefix": "@includeUnless",
    "body": ["@includeUnless(${1:condition}, '${2:view}')"],
    "description": "Blade includeUnless"
  },
  "@includeFirst": {
    "prefix": "@includeFirst",
    "body": ["@includeFirst([${1:'view1', 'view2'}])"],
    "description": "Blade includeFirst"
  },
  "@each": {
    "prefix": "@each",
    "body": ["@each('${1:view}', ${2:\\$items}, '${3:item}')"],
    "description": "Blade each"
  },
  "@component": {
    "prefix": "@component",
    "body": ["@component('${1:component}')", "\t$0", "@endcomponent"],
    "description": "Blade component block"
  },
  "@slot": {
    "prefix": "@slot",
    "body": ["@slot('${1:name}')", "\t$0", "@endslot"],
    "description": "Blade slot block"
  },
  "@push": {
    "prefix": "@push",
    "body": ["@push('${1:name}')", "\t$0", "@endpush"],
    "description": "Blade push block"
  },
  "@prepend": {
    "prefix": "@prepend",
    "body": ["@prepend('${1:name}')", "\t$0", "@endprepend"],
    "description": "Blade prepend block"
  },
  "@pushOnce": {
    "prefix": "@pushOnce",
    "body": ["@pushOnce('${1:name}')", "\t$0", "@endPushOnce"],
    "description": "Blade pushOnce block"
  },
  "@stack": {
    "prefix": "@stack",
    "body": ["@stack('${1:name}')"],
    "description": "Blade stack"
  },
  "@once": {
    "prefix": "@once",
    "body": ["@once", "\t$0", "@endonce"],
    "description": "Blade once block"
  },
  "@verbatim": {
    "prefix": "@verbatim",
    "body": ["@verbatim", "\t$0", "@endverbatim"],
    "description": "Blade verbatim block"
  },
  "@csrf": {
    "prefix": "@csrf",
    "body": ["@csrf"],
    "description": "Blade CSRF token"
  },
  "@method": {
    "prefix": "@method",
    "body": ["@method('${1:PUT}')"],
    "description": "Blade method spoofing"
  },
  "@error": {
    "prefix": "@error",
    "body": ["@error('${1:field}')", "\t$0", "@enderror"],
    "description": "Blade error block"
  },
  "@props": {
    "prefix": "@props",
    "body": ["@props([${1}])"],
    "description": "Blade props"
  },
  "@php": {
    "prefix": "@php",
    "body": ["@php", "\t$0", "@endphp"],
    "description": "Blade PHP block"
  },
  "@env": {
    "prefix": "@env",
    "body": ["@env('${1:production}')", "\t$0", "@endenv"],
    "description": "Blade env block"
  },
  "@production": {
    "prefix": "@production",
    "body": ["@production", "\t$0", "@endproduction"],
    "description": "Blade production block"
  },
  "@isset": {
    "prefix": "@isset",
    "body": ["@isset(${1:\\$variable})", "\t$0", "@endisset"],
    "description": "Blade isset block"
  },
  "@empty": {
    "prefix": "@empty",
    "body": ["@empty(${1:\\$variable})", "\t$0", "@endempty"],
    "description": "Blade empty block"
  },
  "@unless": {
    "prefix": "@unless",
    "body": ["@unless(${1:condition})", "\t$0", "@endunless"],
    "description": "Blade unless block"
  },
  "@selected": {
    "prefix": "@selected",
