  "@checked": {
    "prefix": "@checked",
    "body": ["@checked(${1:condition})"],
    "description": "Blade checked attribute"
  },
  "@disabled": {
    "prefix": "@disabled",
    "body": ["@disabled(${1:condition})"],
    "description": "Blade disabled attribute"
  },
  "@readonly": {
    "prefix": "@readonly",
    "body": ["@readonly(${1:condition})"],
    "description": "Blade readonly attribute"
  },
  "@required": {
    "prefix": "@required",
    "body": ["@required(${1:condition})"],
    "description": "Blade required attribute"
  },
  "@class": {
    "prefix": "@class",
    "body": ["@class([${1:'class' => condition}])"],
    "description": "Blade conditional class"
  },
  "@style": {
    "prefix": "@style",
    "body": ["@style([${1:'style' => condition}])"],
