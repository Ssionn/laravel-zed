  },
  "@teleport": {
    "prefix": "@teleport",
    "body": ["@teleport('${1:selector}')", "\t$0", "@endteleport"],
    "description": "Blade teleport block"
  },
  "@fragment": {
    "prefix": "@fragment",
    "body": ["@fragment('${1:name}')", "\t$0", "@endfragment"],
