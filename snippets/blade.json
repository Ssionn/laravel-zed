  },
  "@json": {
    "prefix": "@json",
    "body": ["@json(${1:\\$variable})"],
    "description": "Blade JSON output"
  },
  "@dd": {
    "prefix": "@dd",
    "body": ["@dd(${1:\\$variable})"],
    "description": "Blade dd"
  },
  "@dump": {
